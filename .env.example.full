# GreenPulse Environment Configuration

# PostgreSQL Database
POSTGRES_USER=greenpulse
POSTGRES_PASSWORD=greenpulse_password
POSTGRES_DB=greenpulse

# Backend API
DATABASE_URL=postgresql://greenpulse:greenpulse_password@db:5432/greenpulse
API_TITLE=GreenPulse Backend API
API_VERSION=1.0.0
DEBUG=false

# Frontend
VITE_API_URL=http://localhost:8000

# pgAdmin (Optional)
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
API_URL=http://localhost:8000
